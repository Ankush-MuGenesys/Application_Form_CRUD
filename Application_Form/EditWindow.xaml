<Window x:Class="Application_Form.EditWindow"

        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

        Title="Edit User" Height="300" Width="400">
    <Grid>
        <Button Content="Update User" x:Name="UpdateUserButton" Click="UpdateUserButton_Click"
                Width="120" Height="40" HorizontalAlignment="Left" Margin="30"/>

        <Button Content="Delete User" x:Name="DeleteUserButton" Click="DeleteUserButton_Click"
                Width="120" Height="40" HorizontalAlignment="Right" Margin="30"/>

        <TextBox x:Name="IdTextBox" Height="20" Width="40" Margin="10"/>

        <Button Content="← Back" Click="BackButton_Click" HorizontalAlignment="Right" VerticalAlignment="Bottom" Width="80" Height="30"/>
    </Grid>
</Window>