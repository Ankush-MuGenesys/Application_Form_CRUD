<Window x:Class="Application_Form.FileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="File Window" Height="300" Width="400">
    <Grid>
        <StackPanel Orientation="Vertical" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10">
            <Button Content="Get Data in Binary/JSON" Click="GetUserData_Click" Width="200" Height="50" Margin="0,5,0,5"/>
            <Button Content="View CSV" Click="ViewCsv_Click" Width="200" Height="50" Margin="0,5,0,5"/>
            <Button Content="Download CSV" Click="DownloadCsv_Click" Width="200" Height="50" Margin="0,5,0,5"/>
        </StackPanel>
    </Grid>
</Window>