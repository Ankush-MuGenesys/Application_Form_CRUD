<Window x:Class="Application_Form.LoginPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Application_Form"
        mc:Ignorable="d"
        Title="LoginPage" Height="450" Width="800">
    <Grid Background="#F0F0F0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="auto" />
        </Grid.RowDefinitions>

        <StackPanel Margin="40" VerticalAlignment="Center">
            <TextBlock Text="Username:" Margin="0,0,0,5"/>
            <TextBox x:Name="txtUsername" Height="30" />

            <TextBlock Text="Password:" Margin="0,10,0,5"/>
            <PasswordBox x:Name="txtPassword" Height="30" />

            <Button Content="Login" Width="100" Height="30" Margin="0,15,0,0" Click="Login_Click" HorizontalAlignment="Left"/>
        </StackPanel>
    </Grid>

</Window>
