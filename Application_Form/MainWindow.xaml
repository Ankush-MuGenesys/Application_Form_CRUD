<Window x:Class="Application_Form.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Application_Form"
        mc:Ignorable="d"
        Title="Application Form" Height="600" Width="800">
        

    <Grid>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
           
            <RowDefinition Height="*"/>
        
        </Grid.RowDefinitions>

       
        <Menu Grid.Row="0" IsMainMenu="True">
            <MenuItem Header="File" Click="FileMenuItem_Click"/>
            <MenuItem Header="Edit"  Click="EditMenuItem_Click"/>
            <MenuItem Header="View" Click="ViewMenuItem_Click"/>
        </Menu>

     
        <StackPanel Grid.Row="1" Margin="20,20,-438,-389">
            <Label Content="Name:" />
            <TextBox x:Name="NameTextBox" />

            <Label Content="ID:" />
            <TextBox x:Name="IdTextBox" />

            <Label Content="Email:" />
            <TextBox x:Name="EmailTextBox" />

            <Label Content="Address:" />
            <TextBox x:Name="AddressTextBox" Height="60" AcceptsReturn="True"/>

            <Button Content="Submit" Margin="0 10 0 0" Click="SubmitButton_Click"/>
            <Button Content="Clear Data" Margin="0 10 0 0" Click="ClearButton_Click"/>

            <Button Content="Show Image" Click="ShowImageButton_Click" Margin="0 10 0 0"/>
            <Button Content="Hide Image" Click="HideImageButton_Click" Margin="0 10 0 0"/>

           


            <Image x:Name="DisplayedImage"
                   Source="C:\Users\admin\Downloads\mugenesys_software_pvt_ltd_logo.jpg"
                   Width="200"
                   Height="200"
                   Visibility="Collapsed"/>
        </StackPanel>
    </Grid>
</Window>
