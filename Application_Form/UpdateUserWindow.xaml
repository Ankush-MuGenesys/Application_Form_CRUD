<Window x:Class="Application_Form.UpdateUserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update User" Height="350" Width="400">
    
   
    <Grid>
        <Button Content="← Back" Click="BackButton_Click" HorizontalAlignment="Right" VerticalAlignment="Bottom" Width="80" Height="30"/>
        <StackPanel Margin="20">
            <Label Content="Enter User ID:"/>
            <TextBox x:Name="IdTextBox"/>

            <Label Content="New Name:"/>
            <TextBox x:Name="NameTextBox"/>

            <Label Content="New Email:"/>
            <TextBox x:Name="EmailTextBox"/>

            <Label Content="New Address:"/>
            <TextBox x:Name="AddressTextBox"/>

            <Button Content="Update User" Click="UpdateUser_Click" Margin="0,10,0,0"/>
        </StackPanel>

        <Button Content="← Back" Click="BackButton_Click" HorizontalAlignment="Right" VerticalAlignment="Bottom" Width="80" Height="30"/>
    </Grid>
</Window>