<Window x:Class="Application_Form.ViewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="User Data" Height="400" Width="600">
    <Grid>
        <Button Content="View All Users" Click="ViewUsersButton_Click" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="10"/>
        <ListBox x:Name="UserListBox" Margin="10" VerticalAlignment="Bottom" Height="300"/>

        <DataGrid x:Name="UserDataGrid" AutoGenerateColumns="True" Margin="10" Height="300"/>
    </Grid>
</Window>